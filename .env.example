SHOPIFY_SHOP_DOMAIN=your-shop.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SHOPIFY_APP_CONFIG=shopify.app.products-get-new.toml
SHOPIFY_API_VERSION=2026-04
SHOPIFY_LOCALE=lv
SHOPIFY_STORE_URL=https://your-public-store.com
SALIDZINI_OUTPUT_FILE=public/miglavita_salidzini.xml
KURPIRKT_OUTPUT_FILE=public/miglavita_kurpirkt.xml
FEED_REFRESH_TIME=05:00

# Optional defaults for feed-specific fields.
DEFAULT_USED=0
DEFAULT_ADULT=no
DEFAULT_OVER_THE_COUNTER_MEDICINE=0

# Optional Shopify metafield mapping.
# Format: namespace.key
MPN_METAFIELD=custom.mpn
EAN_METAFIELD=custom.ean
MODEL_METAFIELD=custom.model
COLOR_METAFIELD=custom.color
